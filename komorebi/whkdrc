.shell powershell

# Reload whkd configuration
# f24 + o                 : taskkill /f /im whkd.exe && start /b whkd # if shell is cmd
f24 + o                 : taskkill /f /im whkd.exe; Start-Process whkd -WindowStyle hidden # if shell is pwsh / powershell
f24 + shift + o         : komorebic reload-configuration

f24 + i                 : komorebic toggle-shortcuts

# App shortcuts - these require shell to be pwsh / powershell
# The apps will be focused if open, or launched if not open
# f24 + f                 : if ($wshell.AppActivate('Firefox') -eq $False) { start firefox }
# f24 + b                 : if ($wshell.AppActivate('Chrome') -eq $False) { start chrome }

f24 + q                 : komorebic close
f24 + m                 : komorebic minimize

# Focus windows
f24 + h                 : komorebic focus left
f24 + j                 : komorebic focus down
f24 + k                 : komorebic focus up
f24 + l                 : komorebic focus right
f24 + shift + oem_4     : komorebic cycle-focus previous # oem_4 is [
f24 + shift + oem_6     : komorebic cycle-focus next # oem_6 is ]

# Move windows
f24 + shift + h         : komorebic move left
f24 + shift + j         : komorebic move down
f24 + shift + k         : komorebic move up
f24 + shift + l         : komorebic move right
f24 + shift + return    : komorebic promote

# Stack windows
f24 + left              : komorebic stack left
f24 + down              : komorebic stack down
f24 + up                : komorebic stack up
f24 + right             : komorebic stack right
f24 + oem_1             : komorebic unstack # oem_1 is ;
f24 + oem_4             : komorebic cycle-stack previous # oem_4 is [
f24 + oem_6             : komorebic cycle-stack next # oem_6 is ]

# Resize
f24 + oem_plus          : komorebic resize-axis horizontal increase
f24 + oem_minus         : komorebic resize-axis horizontal decrease
f24 + shift + oem_plus  : komorebic resize-axis vertical increase
f24 + shift + oem_minus : komorebic resize-axis vertical decrease

# Manipulate windows
f24 + t                 : komorebic toggle-float
f24 + shift + f         : komorebic toggle-monocle

# Window manager options
f24 + shift + r         : komorebic retile
f24 + p                 : komorebic toggle-pause

# Layouts
f24 + x                 : komorebic flip-layout horizontal
f24 + y                 : komorebic flip-layout vertical

# Workspaces
f24 + 1                 : komorebic focus-workspace 0
f24 + 2                 : komorebic focus-workspace 1
f24 + 3                 : komorebic focus-workspace 2
f24 + 4                 : komorebic focus-workspace 3
f24 + 5                 : komorebic focus-workspace 4
f24 + 6                 : komorebic focus-workspace 5
f24 + 7                 : komorebic focus-workspace 6
f24 + 8                 : komorebic focus-workspace 7

# Move windows across workspaces
f24 + shift + 1         : komorebic move-to-workspace 0
f24 + shift + 2         : komorebic move-to-workspace 1
f24 + shift + 3         : komorebic move-to-workspace 2

